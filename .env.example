# ============================================
# NetworkNav (Jynx) — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# Variables marked [Required] must be set for the app to work.
# Variables marked [Optional] enable additional features.

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Authentication [Required] ----
# Minimum 32 characters each. Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=

# ---- Admin ----
# Comma-separated emails: promoted to role=admin on login (password or SSO) if still "user".
# Also gates /api/matchmaking/compute-matches. Example:
# ADMIN_EMAILS=you@company.com,colleague@company.com
ADMIN_EMAILS=

# ---- Supabase [Required] ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- About Jynx team [Optional] ----
# If set, the About modal uses these user_profiles.id values (otherwise it resolves by name/email).
# NEXT_PUBLIC_TEAM_CAMILA_USER_ID=
# NEXT_PUBLIC_TEAM_AUSTIN_USER_ID=
# NEXT_PUBLIC_TEAM_LISA_USER_ID=

# ---- Database ----
# PostgreSQL connection string (used by Drizzle for migrations only)
DATABASE_URL=

# ---- AI Provider ----
# "openai", "vertex", or "openrouter" (free-tier generative via OpenRouter)
AI_PROVIDER=openrouter

# Embedding vector dimensions — must match your Supabase VECTOR() column size
EMBEDDING_DIMENSIONS=1536

# [Required when AI_PROVIDER=openai]
OPENAI_API_KEY=
# [Optional] Chat model for generative copy (default gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# [Required when AI_PROVIDER=openrouter]
# OpenRouter uses the OpenAI-compatible API. Free models (":free" suffix) have
# daily request limits tied to credit balance; staying above ~$10 in credits
# unlocks the higher-quota tier. See https://openrouter.ai/docs
OPENROUTER_API_KEY=
# [Preferred] Ordered fallback chain (comma-separated, max 3 entries —
# OpenRouter hard-caps the server-side `models` array at 3). First entry is
# primary; remaining entries are fallbacks that OpenRouter tries in-request
# when the primary returns 429 or any other error.
# OPENROUTER_MODELS=google/gemma-4-31b-it:free,openai/gpt-oss-120b:free,nvidia/nemotron-3-super-120b-a12b:free
# [Single-model back-compat] Only used if OPENROUTER_MODELS is unset.
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# [Required when AI_PROVIDER=vertex]
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# ---- SAML SSO [Optional] ----
# Deployed (e.g. Vercel) usually has SSO_ENABLED=true + cert — same vars work locally.
# Enable SSO click-through to IdP (required for /api/auth/sso/login to redirect)
SSO_ENABLED=false
# When true, hides email/password form and only shows SSO button (use in production)
SSO_FORCE=false
# IdP SSO URL. If omitted while SSO_ENABLED=true, defaults to Strategic Education prod:
#   https://sso.strategiced.com/idp/SSO.saml2
# For dev IdP, set explicitly: https://devsso.strategiced.com/idp/SSO.saml2
SAML_ENTRY_POINT=
# SP Entity ID (defaults to APP_URL/api/auth/sso/metadata)
SAML_ISSUER=
# Assertion Consumer Service URL (defaults to APP_URL/api/auth/sso/callback)
SAML_CALLBACK_URL=
# IdP X.509 signing certificate (PEM). On Vercel, paste the full PEM here.
# Locally: copy from Vercel env or your IdP admin. Options:
#   - SAML_IDP_CERT="-----BEGIN CERTIFICATE-----\n..." (escape newlines as \n)
#   - SAML_IDP_CERT_PATH=/absolute/path/to/idp.pem
#   - Place file at certs/strategic-ed-prod-idp.pem (the certs/ folder is gitignored)
SAML_IDP_CERT=
# Optional absolute/relative path to IdP PEM file
SAML_IDP_CERT_PATH=
# SP signing certificate and private key (PEM, generated via openssl)
SAML_SP_CERT=
SAML_SP_KEY=

# ---- Google Calendar Integration [Optional] ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ---- Microsoft Outlook/Teams Integration [Optional] ----
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/integrations/microsoft/callback
