# ============================================
# NetworkNav (Jynx) — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# Variables marked [Required] must be set for the app to work.
# Variables marked [Optional] enable additional features.

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Authentication [Required] ----
# Minimum 32 characters each. Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=

# ---- Admin ----
# Comma-separated emails that can trigger batch match computation
ADMIN_EMAILS=

# ---- Supabase [Required] ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Database ----
# PostgreSQL connection string (used by Drizzle for migrations only)
DATABASE_URL=

# ---- AI Provider ----
# "openai" (default) or "vertex"
AI_PROVIDER=openai

# Embedding vector dimensions — must match your Supabase VECTOR() column size
EMBEDDING_DIMENSIONS=1536

# [Required when AI_PROVIDER=openai]
OPENAI_API_KEY=
# [Optional] Chat model for Jynx / generative copy (default gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# [Required when AI_PROVIDER=vertex]
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# ---- SAML SSO [Optional] ----
# Enable SSO click-through to IdP (required for redirect to devsso.strategiced.com)
SSO_ENABLED=false
# When true, hides email/password form and only shows SSO button (use in production)
SSO_FORCE=false
# IdP SSO URL. If omitted while SSO_ENABLED=true, defaults to Strategic Education dev:
#   https://devsso.strategiced.com/idp/SSO.saml2
SAML_ENTRY_POINT=
# SP Entity ID (defaults to APP_URL/api/auth/sso/metadata)
SAML_ISSUER=
# Assertion Consumer Service URL (defaults to APP_URL/api/auth/sso/callback)
SAML_CALLBACK_URL=
# IdP X.509 signing certificate (PEM). Match values from Vercel / identity team.
# Or set SAML_IDP_CERT_PATH, or place PEM at certs/strategic-ed-dev-idp.pem (see .gitignore)
SAML_IDP_CERT=
# Optional absolute/relative path to IdP PEM file
SAML_IDP_CERT_PATH=
# SP signing certificate and private key (PEM, generated via openssl)
SAML_SP_CERT=
SAML_SP_KEY=

# ---- Google Calendar Integration [Optional] ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ---- Microsoft Outlook/Teams Integration [Optional] ----
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/integrations/microsoft/callback
